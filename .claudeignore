# .claudeignore — files Claude should skip when reading this codebase
# Syntax mirrors .gitignore

# ── Build output ─────────────────────────────────────────────────────────────
target/
**/*.rs.bk

# ── Lock file — large, not useful context ────────────────────────────────────
Cargo.lock

# ── Tree-sitter compiled grammars ────────────────────────────────────────────
grammars/
**/*.so
**/*.dylib
**/*.dll
**/*.wasm

# ── Assets (binary) ──────────────────────────────────────────────────────────
assets/

# ── CI config — rarely relevant to code tasks ────────────────────────────────
.github/

# ── OS / IDE noise ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.iml

# ── Runtime session files ────────────────────────────────────────────────────
*.crabide-session
.crabide/cache/

